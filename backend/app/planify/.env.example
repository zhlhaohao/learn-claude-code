# Environment Variables Template for Refactored Agent System
# Copy this file to .env and fill in your values

# Required: Model ID to use
MODEL_ID=your-model-id

# Optional: Custom API endpoint (removes default auth token if set)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: API key (used for web_search via ZhipuAI)
# ANTHROPIC_API_KEY=your-api-key
